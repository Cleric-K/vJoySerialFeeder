root = true

[*]
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_style = tab
indent_size = 4
end_of_line = crlf

[*.{csproj,sln,xml,resx}]
indent_style = space
indent_size = 2
end_of_line = crlf

[*.md]
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2
end_of_line = lf
